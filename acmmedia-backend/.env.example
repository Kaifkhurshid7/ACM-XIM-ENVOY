# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (MongoDB Atlas recommended for production)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/acmmedia

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret key for signing JWT tokens (use a strong random string in production)
JWT_SECRET=your_jwt_secret_here

# Secret key required for admin account registration
ADMIN_SECRET=your_admin_secret_here

# ─── External APIs ───────────────────────────────────────────────────────────
# NewsAPI key for fetching technology news (https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
# Port for the Express server (defaults to 5000)
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
